# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=silverlink
POSTGRES_PASSWORD=silverlink_secret
POSTGRES_DB=silverlink

# InfluxDB
INFLUX_HOST=http://influxdb:8086
INFLUX_TOKEN=silverlink-influx-token
INFLUX_ORG=silverlink
INFLUX_BUCKET=telemetry

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka
KAFKA_BROKERS=kafka:9092

# MQTT
MQTT_BROKER_URL=mqtt://mosquitto:1883
MQTT_USERNAME=silverlink
MQTT_PASSWORD=mqtt_secret

# JWT
JWT_SECRET=silverlink_jwt_super_secret_key_change_in_prod
JWT_EXPIRES_IN=7d

# Notification Channels
FCM_SERVER_KEY=your_firebase_server_key
MAXIS_SMS_API_KEY=your_maxis_sms_api_key
MAXIS_SMS_API_URL=https://api.maxis.com.my/sms/v1/send
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=alerts@silverlink.maxis.com.my

# Emergency Services
AMBULANCE_API_URL=https://api.999.gov.my/ambulance
AMBULANCE_API_KEY=your_ambulance_api_key
PDRM_API_URL=https://api.pdrm.gov.my/emergency
PDRM_API_KEY=your_pdrm_api_key

# Service Ports
API_GATEWAY_PORT=3000
DEVICE_MANAGEMENT_PORT=3001
TELEMETRY_INGESTION_PORT=3002
ALERT_PROCESSING_PORT=3003
USER_PROFILE_PORT=3004
NOTIFICATION_PORT=3005
ANALYTICS_PORT=3006
EMERGENCY_RESPONSE_PORT=3007

# Internal service URLs (for API gateway routing)
DEVICE_MANAGEMENT_URL=http://device-management:3001
TELEMETRY_INGESTION_URL=http://telemetry-ingestion:3002
ALERT_PROCESSING_URL=http://alert-processing:3003
USER_PROFILE_URL=http://user-profile:3004
NOTIFICATION_URL=http://notification:3005
ANALYTICS_URL=http://analytics:3006
EMERGENCY_RESPONSE_URL=http://emergency-response:3007
